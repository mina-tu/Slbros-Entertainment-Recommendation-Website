            },
            {
              "id": "ppkb_02", "elType": "widget", "widgetType": "icon-box",
              "settings": {
                "selected_icon": { "value": "fas fa-shield-alt", "library": "fa-solid" }, "view": "default", "position": "left", "title_text": "", "description_text": "本網站<strong>不會將使用者個人資料出售、出租或提供給無關第三方</strong>作商業用途。", "primary_color": "#DEF243", "icon_size": { "unit": "px", "size": 22 }, "description_color": "#C3CAD8", "content_vertical_alignment": "top", "text_align": "left",
                "_background_background": "classic", "_background_color": "rgba(67,38,154,0.22)", "_border_border": "solid", "_border_width": { "unit": "px", "top": "1", "right": "1", "bottom": "1", "left": "4", "isLinked": false }, "_border_color": "rgba(118,86,215,0.34)", "_padding": { "unit": "px", "top": "18", "right": "22", "bottom": "18", "left": "22", "isLinked": false }, "_margin": { "unit": "px", "top": "10", "right": "0", "bottom": "8", "left": "0", "isLinked": false }
              },
              "elements": []
