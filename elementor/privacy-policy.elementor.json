                ],
                "space_between": { "unit": "px", "size": 11 }, "icon_color": "#7656D7", "icon_size": { "unit": "px", "size": 8 }, "text_color": "#C3CAD8", "text_typography_typography": "custom", "text_typography_font_size": { "unit": "px", "size": 16 }
              },
              "elements": []
            },
            { "id": "pptx_07b", "elType": "widget", "widgetType": "text-editor", "settings": { "editor": "<p>如有相關需求，可透過本網站聯絡方式與我們聯繫。</p>", "text_color": "#C3CAD8", "typography_typography": "custom", "typography_font_size": { "unit": "px", "size": 16 }, "typography_line_height": { "unit": "em", "size": 1.9 } }, "elements": [] },

            { "id": "ppnum08", "elType": "widget", "widgetType": "heading", "settings": { "title": "08", "header_size": "h6", "title_color": "#B5A8F0", "typography_typography": "custom", "typography_font_size": { "unit": "px", "size": 14 }, "typography_font_weight": "800", "typography_letter_spacing": { "unit": "px", "size": 1.2 }, "_margin": { "unit": "px", "top": "30", "right": "0", "bottom": "0", "left": "0", "isLinked": false } }, "elements": [] },
